---
interface Props {
	title: string;
	detail?: string;
	rotate?: number;
	delay?: number;
	class?: string;
}
const { title, detail, rotate = 3, delay = 0, class: className = '' } = Astro.props;
const style = `--spent-rot: rotate(${rotate}deg); transform: var(--spent-rot); animation-delay: ${delay}s;`;
---
<div class={`overlay-card overlay-sync ${className}`} style={style}>
	<span class="pulse-dot" aria-hidden="true"></span>
	<div class="body">
		<div class="title">{title}</div>
		{detail && <div class="detail">{detail}</div>}
	</div>
</div>

<style>
	.overlay-card {
		position: absolute;
		background: #fff;
		border-radius: 12px;
		padding: 12px 14px;
		box-shadow: var(--spent-shadow-overlay);
		font-family: var(--spent-font-sans);
		font-size: 0.75rem;
		z-index: 3;
		animation: spent-float 6s ease-in-out infinite;
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.pulse-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--spent-vibrant);
		animation: spent-pulse 2s infinite;
		flex-shrink: 0;
	}
	.body { display: flex; flex-direction: column; gap: 2px; }
	.title { color: var(--spent-fg); font-weight: 500; }
	.detail {
		font-family: var(--spent-font-mono);
		font-size: 0.625rem;
		color: var(--spent-fg-muted);
	}
</style>
