---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---
<footer class="footer">
	<div class="spent-wrap inner">
		<div class="row top">
			<a class="brand" href={base || '/'}>Spent</a>
			<nav class="links" aria-label="Footer">
				<a href="https://github.com/Shaya16/Spent">GitHub</a>
				<a href={`${base}/getting-started`}>Docs</a>
				<a href={`${base}/security-and-privacy`}>Security</a>
				<a href={`${base}/disclaimer`}>Disclaimer</a>
				<a href="https://github.com/Shaya16/Spent/blob/main/LICENSE">License</a>
			</nav>
		</div>
		<div class="copyright">
			© {year} · MIT licensed · Built in Israel · No tracking on this site either
		</div>
	</div>
</footer>

<style>
	.footer {
		background: var(--spent-primary-dark);
		color: var(--spent-bg);
		padding: 2.25rem 0 1.75rem;
	}
	.inner {
		font-family: var(--spent-font-sans);
	}
	.row.top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}
	.brand {
		font-family: var(--spent-font-serif);
		font-style: italic;
		font-weight: 500;
		font-size: 1.1rem;
		color: var(--spent-bg);
		text-decoration: none;
	}
	.links {
		display: flex;
		flex-wrap: wrap;
		gap: 1.1rem;
		font-size: 0.8rem;
	}
	.links a {
		color: var(--spent-bg);
		opacity: 0.75;
		text-decoration: none;
	}
	.links a:hover { opacity: 1; text-decoration: underline; text-underline-offset: 3px; }

	.copyright {
		margin-top: 1rem;
		padding-top: 1rem;
		border-top: 1px solid rgba(250, 241, 220, 0.1);
		font-family: var(--spent-font-mono);
		font-size: 0.625rem;
		opacity: 0.55;
		letter-spacing: 0.05em;
	}
</style>
